{
  "name": "@chronary/n8n-nodes-chronary",
  "version": "0.1.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "n8n community node for Chronary — an agent-native calendar API. Manage calendars, events, availability, and agents.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "chronary",
    "calendar",
    "scheduling",
    "ai-agents"
  ],
  "license": "Apache-2.0",
  "homepage": "https://chronary.ai",
  "author": "Chronary <gautam@chronary.ai> (https://chronary.ai)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chronary/n8n-nodes-chronary"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "lint": "eslint credentials nodes package.json",
    "lintfix": "eslint credentials nodes package.json --fix",
    "prepublishOnly": "tsc && gulp build:icons"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ChronaryApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Chronary/Chronary.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "^1.60.0",
    "typescript": "^5.5.0"
  }
}
